.member-management-container {
  padding: 20rpx;
  background-color: #f4f4f4;
}

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.back-icon {
  margin-right: 15rpx;
}

.back-img {
  width: 45rpx;
  height: 45rpx;
}

.title {
  font-size: 34rpx;
  color: #007aff;
  font-weight: 700;
}

.add-button {
  background-color: #007aff;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
}

.member-list {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.25);
}

.member-item {
  border-bottom: 1px solid #ccc;
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
}

.member-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  width: 100%;
}

.member-level {
  font-size: 26rpx;
  color: #555;
  margin-top: 5rpx;
}

.member-remaining-times {
  font-size: 26rpx;
  color: #555;
  margin-top: 5rpx;
}

.edit-button,
.delete-button {
  background-color: #007aff;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 10rpx;
}

.delete-button {
  background-color: #ff4d4f;
}

/* 模态框样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-container {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 20rpx;
  width: 80%;
}

.modal-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
  text-align: center;
}

.modal-input {
  width: 100%;
  font-size: 26rpx;
  padding: 10rpx;
  border: 1px solid #ccc;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.modal-buttons {
  display: flex;
  justify-content: space-around;
}

.save-button,
.cancel-button {
  background-color: #007aff;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
}

.cancel-button {
  background-color: #ccc;
}