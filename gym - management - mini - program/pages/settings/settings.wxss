/* 整体容器 */
.settings-container {
  padding: 20rpx;
  background-color: #f4f4f4;
}

/* 顶部导航 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}
.back-icon {
  margin-right: 15rpx;
}
.back-img {
  width: 45rpx;
  height: 45rpx;
}
.title {
  font-size: 34rpx;
  color: #007aff;
  font-weight: 700;
}

/* 表单部分 */
.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.form-label {
  font-size: 26rpx;
  color: #555;
  width: 150rpx;
  text-align: right;
  margin-right: 20rpx;
}
.form-input {
  flex: 1;
  font-size: 26rpx;
  padding: 10rpx;
  border: 1px solid #ccc;
  border-radius: 8rpx;
}

/* 提交按钮 */
.submit-button {
  background-color: #007aff;
  color: #fff;
  font-size: 28rpx;
  padding: 15rpx;
  border-radius: 10rpx;
  text-align: center;
}
.submit-button:active {
  background-color: #0056b3;
}