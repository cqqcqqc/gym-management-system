<view class="settings-container">
  <!-- 顶部导航 -->
  <view class="top-nav">
    <navigator url="/pages/personalCenter/personalCenter" class="back-icon">
      <image src="/assets/icon/back.png" class="back-img"></image>
    </navigator>
    <text class="title">设置账户相关信息</text>
  </view>
  <!-- 表单部分 -->
  <form bindsubmit="submitForm">
    <view class="form-item">
      <label class="form-label">昵称：</label>
      <input type="text" placeholder="请输入昵称" name="nickname" class="form-input" />
    </view>
    <view class="form-item">
      <label class="form-label">手机号：</label>
      <input type="number" placeholder="请输入手机号" name="phone" class="form-input" />
    </view>
    <view class="form-item">
      <label class="form-label">邮箱：</label>
      <input type="email" placeholder="请输入邮箱" name="email" class="form-input" />
    </view>
    <view class="form-item">
      <label class="form-label">密码：</label>
      <input type="password" placeholder="请输入密码" name="password" class="form-input" />
    </view>
    <button formType="submit" class="submit-button">保存设置</button>
  </form>
</view>