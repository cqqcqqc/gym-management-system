.activity-container {
  padding: 20rpx;
  background-color: #f4f4f4;
}

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.back-icon {
  margin-right: 15rpx;
}

.back-img {
  width: 45rpx;
  height: 45rpx;
}

.title {
  font-size: 34rpx;
  color: #007aff;
  font-weight: 700;
}

.activity-info {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.25);
  text-align: center;
}

.activity-image {
  width: 100%;
  height: auto;
  object-fit: cover;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}

.activity-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 5rpx;
}

.activity-date {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 10rpx;
}

.activity-intro {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.sign-up-button {
  background-color: #007aff;
  color: #fff;
  font-size: 28rpx;
  padding: 15rpx;
  border-radius: 10rpx;
  text-align: center;
}

.sign-up-button:active {
  background-color: #0056b3;
}