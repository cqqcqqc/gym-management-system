.course-list-container {
  padding: 32rpx 28rpx;
  background: #f5f5f5;
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}
.title {
  font-size: 40rpx;
  color: #2c2c2c;
  font-weight: 700;
}
.about-link {
  font-size: 34rpx;
  color: #1AAD19;
  text-decoration: none;
}
.course-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  padding: 32rpx 36rpx;
  margin-bottom: 36rpx;
  border-radius: 36rpx;
  box-shadow: 0 24rpx 48rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.15s;
}
.course-item-image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 24rpx;
  margin-right: 40rpx;
  object-fit: cover;
}
.course-item-content {
  flex: 1;
}
.course-title {
  font-size: 38rpx;
  color: #2c2c2c;
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 16rpx;
}
.course-item:active {
  transform: scale(0.96);
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.1);
}