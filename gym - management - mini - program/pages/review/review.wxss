.review-container {
  padding: 20rpx;
  background-color: #f4f4f4;
}

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.back-icon {
  margin-right: 15rpx;
}

.back-img {
  width: 45rpx;
  height: 45rpx;
}

.title {
  font-size: 34rpx;
  color: #007aff;
  font-weight: 700;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: #555;
  display: block;
  margin-bottom: 5rpx;
}

.form-input {
  width: 100%;
  font-size: 26rpx;
  padding: 10rpx;
  border: 1px solid #ccc;
  border-radius: 8rpx;
}

.form-textarea {
  width: 100%;
  font-size: 26rpx;
  padding: 10rpx;
  border: 1px solid #ccc;
  border-radius: 8rpx;
  min-height: 100rpx;
}

.picker-view {
  font-size: 26rpx;
  color: #333;
  padding: 10rpx;
  border: 1px solid #ccc;
  border-radius: 8rpx;
  background-color: #fff;
}

.submit-button {
  background-color: #007aff;
  color: #fff;
  font-size: 28rpx;
  padding: 15rpx;
  border-radius: 10rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.submit-button:active {
  background-color: #0056b3;
}

.review-list {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.25);
}

.review-item {
  border-bottom: 1px solid #ccc;
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
}

.review-course-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.review-content {
  font-size: 26rpx;
  color: #555;
  margin-top: 5rpx;
}

.review-rating {
  font-size: 26rpx;
  color: #555;
  margin-top: 5rpx;
}