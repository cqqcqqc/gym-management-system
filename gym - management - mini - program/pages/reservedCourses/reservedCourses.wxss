.container {
  padding: 20rpx;
  background-color: #f4f4f4;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-align: center;
}

.reserved-course {
  background-color: white;
  border-radius: 15rpx;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.course-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.reservation-info {
  font-size: 24rpx;
  color: #555;
}