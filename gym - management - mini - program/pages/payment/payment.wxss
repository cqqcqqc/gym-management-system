.payment-container {
  padding: 20rpx;
  background-color: #f4f4f4;
}

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.back-icon {
  margin-right: 15rpx;
}

.back-img {
  width: 45rpx;
  height: 45rpx;
}

.title {
  font-size: 34rpx;
  color: #007aff;
  font-weight: 700;
}

.payment-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-label {
  font-size: 26rpx;
  color: #555;
  width: 150rpx;
  text-align: right;
  margin-right: 20rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.payment-method {
  margin-bottom: 20rpx;
}

.method-label {
  font-size: 26rpx;
  color: #555;
  display: block;
  margin-bottom: 10rpx;
}

.radio-label {
  font-size: 26rpx;
  color: #333;
  margin-right: 20rpx;
}

.pay-button {
  background-color: #007aff;
  color: #fff;
  font-size: 28rpx;
  padding: 15rpx;
  border-radius: 10rpx;
  text-align: center;
}

.pay-button:active {
  background-color: #0056b3;
}