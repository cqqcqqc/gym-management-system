<view class="container">
  <!-- 标题 -->
  <text class="title">健身房用户登录</text>

  <!-- 用户名输入框（带图标） -->
  <view class="input-group">
    <image src="/assets/icon/user.png" class="input-icon"></image>
    <input 
      type="text" 
      placeholder="请输入用户名" 
      placeholder-class="placeholder"
      value="{{username}}" 
      bindinput="handleUsernameInput"
    />
  </view>

  <!-- 密码输入框（带图标+可见性按钮） -->
  <view class="input-group">
    <image src="/assets/icon/lock.png" class="input-icon"></image>
    <input 
      type="{{passwordType}}" 
      placeholder="请输入密码" 
      placeholder-class="placeholder"
      value="{{password}}" 
      bindinput="handlePasswordInput"
    />
    <button 
      class="password-eye" 
      bindtap="togglePassword"
      hover-class="none"
    >
      <image 
        src="/assets/icon/{{passwordVisible ? 'eye' : 'eye-off' }}.png" 
        mode="widthFix"
        class="eye-icon"
      ></image>
    </button>
  </view>

  <!-- 登录按钮（带加载状态） -->
  <button 
    class="login-btn" 
    bindtap="handleLogin"
    disabled="{{isLoading}}"
  >
    {{isLoading ? '登录中...' : '登录'}}
  </button>

  <!-- 测试账号提示（开发阶段保留） -->
  <view class="debug-tip">
    测试账号：<text class="debug-account">admin</text> / 密码：<text class="debug-account">123456</text>
  </view>
</view>